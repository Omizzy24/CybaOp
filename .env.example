# CybaOp Frontend (Vercel) — Environment Variables
# Copy to .env.local and fill in real values: cp .env.example .env.local

# ============================================================
# REQUIRED — the app will not function without these
# ============================================================

# SoundCloud OAuth (get from https://soundcloud.com/you/apps)
SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id
SOUNDCLOUD_CLIENT_SECRET=your-soundcloud-client-secret

# Must match the redirect URI registered in your SoundCloud app
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# FastAPI backend URL (Railway in production, localhost in dev)
BACKEND_URL=http://localhost:8000

# ============================================================
# OPTIONAL — defaults are fine for local development
# ============================================================

# Set to "debug" to enable verbose logging in OAuth callback
# LOG_LEVEL=debug
