# CybaOp Backend — Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# SoundCloud OAuth (REQUIRED — get from https://soundcloud.com/you/apps)
SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id
SOUNDCLOUD_CLIENT_SECRET=your-soundcloud-client-secret
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Google Gemini — for AI insights on paid tier (optional for dev)
GOOGLE_API_KEY=

# Database (start Postgres with: docker compose up -d postgres)
DATABASE_URL=postgresql://cybaop:cybaop@localhost:5432/cybaop

# JWT — change this in production
JWT_SECRET=change-this-to-a-random-secret-in-production

# API
API_PORT=8000
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Environment
ENV=development
LOG_LEVEL=debug
RATE_LIMIT_PER_MINUTE=30
