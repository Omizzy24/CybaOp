# CybaOp Backend (Railway) — Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# ============================================================
# REQUIRED — the app will not start without these
# ============================================================

# SoundCloud OAuth (get from https://soundcloud.com/you/apps)
SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id
SOUNDCLOUD_CLIENT_SECRET=your-soundcloud-client-secret

# Database — Neon Postgres connection string
DATABASE_URL=postgresql://cybaop:cybaop@localhost:5432/cybaop

# JWT signing secret — MUST be a strong random string in production
JWT_SECRET=change-this-to-a-random-secret-in-production

# Frontend URL — used for CORS allow-origin
FRONTEND_URL=http://localhost:3000

# ============================================================
# OPTIONAL — defaults are fine for local development
# ============================================================

# SoundCloud redirect URI (used by /auth/token route)
# SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Google Gemini API key — required for AI insights and workflow steps
# GOOGLE_API_KEY=AIza...

# JWT configuration
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_HOURS=720

# Server
# API_PORT=8000
# API_HOST=0.0.0.0

# Environment
# ENV=development
# LOG_LEVEL=debug

# Rate limiting
# RATE_LIMIT_PER_MINUTE=30

# Cache TTLs (seconds)
# CACHE_TTL_PROFILE=3600
# CACHE_TTL_TRACKS=1800
# CACHE_TTL_INSIGHTS=21600
